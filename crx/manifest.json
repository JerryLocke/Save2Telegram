{
  "manifest_version": 3,
  "default_locale": "en",
  "name": "Save2Telegram",
  "description": "Adds a button on Twitter/X media pages to forward media to a Telegram channel through a Telegram Bot.",
  "version": "0.1.0",
  "icons": {
    "16": "icons/icon_16.png",
    "32": "icons/icon_32.png",
    "48": "icons/icon_48.png",
    "128": "icons/icon_128.png"
  },
  "permissions": ["storage", "activeTab", "webRequest"],
  "host_permissions": [
    "https://api.telegram.org/*",
    "https://twitter.com/*",
    "https://x.com/*",
    "https://*.twimg.com/*"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "externally_connectable": {
    "matches": [
      "http://localhost/*",
      "http://127.0.0.1/*"
    ]
  },
 "content_scripts": [
   {
     "matches": ["https://twitter.com/*", "https://x.com/*"],
      "js": ["content.js"],
     "css": ["content.css"],
     "run_at": "document_idle"
   }
 ],
  "action": {
    "default_title": "Save2Telegram",
    "default_icon": {
      "16": "icons/popup_16.png",
      "32": "icons/popup_32.png",
      "48": "icons/icon_48.png",
      "128": "icons/icon_128.png"
    },
    "default_popup": "popup.html"
  }
}
